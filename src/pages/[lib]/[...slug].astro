---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sidebar from "../../components/Sidebar.astro";
import FetchCallout from "../../components/FetchCallout.astro";
import PageToc from "../../components/PageToc.astro";
import { getLibraries, type LibraryMeta } from "../../lib/libraries";
import { getNavTree, getAllLeafPaths, findParentGroupLabel } from "../../lib/nav";
import { getEntry, render } from "astro:content";

export function getStaticPaths() {
  const libraries = getLibraries();
  const paths: {
    params: { lib: string; slug: string };
    props: { lib: LibraryMeta; leafPath: string; leafLabel: string };
  }[] = [];

  for (const lib of libraries) {
    const navTree = getNavTree(lib.id);
    const leaves = getAllLeafPaths(navTree);

    for (const leaf of leaves) {
      // index.md is handled by [lib]/index.astro
      if (leaf.path === "index.md") continue;

      paths.push({
        params: { lib: lib.id, slug: leaf.path.replace(/\.md$/, "") },
        props: { lib, leafPath: leaf.path, leafLabel: leaf.label },
      });
    }
  }

  return paths;
}

interface Props {
  lib: LibraryMeta;
  leafPath: string;
  leafLabel: string;
}

const { lib, leafPath, leafLabel } = Astro.props;
const { slug } = Astro.params;
const navTree = getNavTree(lib.id);
const groupLabel = findParentGroupLabel(navTree, leafPath);

// Render markdown via content collection
const entry = await getEntry("docs", `${lib.id}/${slug}`);
const rendered = entry ? await render(entry) : null;
const Content = rendered?.Content;
const headings = rendered?.headings ?? [];
const data = (entry?.data ?? {}) as Record<string, unknown>;

const pageTitle = (data.title as string | undefined) ?? leafLabel;
const description = data.description as string | undefined;

// Reference page detection: has ref_meta in front-matter
const refMeta = data.ref_meta as Record<string, string> | undefined;
const isRefPage = !!refMeta;

// Build LLM fetch URL for reference pages
const llmUrl = isRefPage
  ? `https://docs.passivehousetools.com/llm/${lib.id}/${slug}.md`
  : undefined;

// Build metadata items from ref_meta
const metaItems = refMeta
  ? Object.entries(refMeta).map(([key, value]) => ({
      label: key.replace(/_/g, " "),
      value,
    }))
  : [];
---

<BaseLayout
  title={`${pageTitle} — ${lib.label} — PH-Tools Docs`}
  activeLib={lib.id}
  hideFooter
>
  <div class="with-sidebar">
    <div class="sidebar-col">
      <Sidebar
        libId={lib.id}
        libLabel={lib.label}
        navTree={navTree}
        currentPath={leafPath}
      />
      {isRefPage && headings.length > 0 && (
        <PageToc headings={headings} />
      )}
    </div>

    <div>
      {isRefPage ? (
        <!-- Reference page: rich header with metadata grid + FetchCallout -->
        <header class="ref-head">
          <div class="ref-head__crumb">
            {groupLabel && (
              <>
                <span>{groupLabel}</span>
                <span class="sep">&rsaquo;</span>
              </>
            )}
            <span class="current">{leafLabel}</span>
          </div>
          <h1 class="ref-head__title">{pageTitle}</h1>
          {description && <p class="ref-head__desc">{description}</p>}
          {metaItems.length > 0 && (
            <div class="ref-head__meta">
              {metaItems.map((item) => (
                <div class="ref-head__meta-item">
                  <span class="k">{item.label}</span>
                  <span class="v">{item.value}</span>
                </div>
              ))}
            </div>
          )}
        </header>
      ) : (
        <!-- Regular content page: simple breadcrumb header -->
        <header class="content-head">
          <div class="content-head__crumb">
            {groupLabel && (
              <>
                <span>{groupLabel}</span>
                <span class="sep">&rsaquo;</span>
              </>
            )}
            <span class="current">{leafLabel}</span>
          </div>
        </header>
      )}

      {isRefPage && llmUrl && (
        <FetchCallout url={llmUrl} />
      )}

      <article class={`article${isRefPage ? " article--ref" : ""}`} data-pagefind-body data-pagefind-meta={`library:${lib.label}`}>
        {Content ? <Content /> : <p>Content not found.</p>}
      </article>

      <footer class="site-footer">
        <div class="site-footer__left">
          <span>PH-TOOLS</span>
          <span>&middot;</span>
          <a href={`https://github.com/${lib.repo}`}>GitHub</a>
          <span>&middot;</span>
          <a href={`https://github.com/${lib.repo}/issues`}>Issues</a>
        </div>
        <div class="site-footer__right">
          <span>docs.passivehousetools.com</span>
        </div>
      </footer>
    </div>
  </div>
</BaseLayout>
